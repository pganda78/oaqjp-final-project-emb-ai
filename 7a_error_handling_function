""" Module to test the Emotion Analysis of a text """
# Import the requests library to handle HTTP requests
import requests
import json

# Define a function named emotion_detector that takes a string input (text_to_analyze)
def emotion_detector(text_to_analyze):
    """ Sentiment analyzer """
    # URL of the emotion detector service
    url_str = 'https://sn-watson-emotion.labs.skills.network/v1/watson.runtime.nlp.v1/NlpService/EmotionPredict'

    # Create a dictionary with the text to be analyzed
    input_obj = { "raw_document": { "text": text_to_analyze } }

    # Set the headers required for the API request
    headers_obj = { "grpc-metadata-mm-model-id": "emotion_aggregated-workflow_lang_en_stock" }

    # Send a POST request to the API with the text and headers
    response = requests.post(url_str, json = input_obj, headers=headers_obj, timeout=10)

    # If the response status code is 200, extract the response text
    if response.status_code == 200:
        formatted_response = json.loads(response.text)
        emotion_dict = formatted_response['emotionPredictions'][0]['emotion']
        emotion_dict['dominant_emotion'] = max(emotion_dict, key=emotion_dict.get)
    elif response.status_code == 400:
        emotion_dict = {
            'anger': None,
            'disgust': None,
            'fear': None,
            'joy': None,
            'sadness': None,
            'dominant_emotion': None
        }
    else:
        emotion_dict = {
            'anger': None,
            'disgust': None,
            'fear': None,
            'joy': None,
            'sadness': None,
            'dominant_emotion': None
        }
  
    return emotion_dict
